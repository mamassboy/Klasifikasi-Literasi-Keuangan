        "# 1. LOAD DATA DARI 1 SHEET GOOGLE FORMS\n",
        "sheet_id = \"1OgBoTgSJ6L-tFtvQYpbFbBYCVdq1op4M\"\n",
        "url = f\"https://docs.google.com/spreadsheets/d/{sheet_id}/export?format=csv\"\n",
        "\n",
        "print(\"Memuat data secara live dari Sheet Tunggal...\")\n",
        "df_clean = pd.read_csv(url)\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(f\"📊 DATA SEBELUM CLEANING: {df_clean.shape[0]} baris\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "# ── STEP 1: Bersihkan Kolom Nomor HP ──────────────────────\n",
        "def bersihkan_hp(nilai):\n",
        "    \"\"\"\n",
        "    Logika:\n",
        "    - Hapus semua karakter non-digit (huruf, spasi, simbol)\n",
        "    - Kecuali tanda + di awal (untuk format +62)\n",
        "    - Jika hasil < 8 digit → bukan nomor valid → NaN\n",
        "    - Jika kolom berisi nama orang → NaN\n",
        "    \"\"\"\n",
        "    if pd.isna(nilai):\n",
        "        return np.nan\n",
        "\n",
        "    nilai = str(nilai).strip()\n",
        "\n",
        "    # Jika value adalah tanda strip saja\n",
        "    if nilai in ['-', '', ' ']:\n",
        "        return np.nan\n",
        "\n",
        "    # Ekstrak angka dari awal string\n",
        "    # Handle format: +62 831-8440-5409\n",
        "    nilai_bersih = re.sub(r'[^\\d+]', '', nilai)\n",
        "\n",
        "    # Konversi +62 ke 0\n",
        "    if nilai_bersih.startswith('+62'):\n",
        "        nilai_bersih = '0' + nilai_bersih[3:]\n",
        "\n",
        "    # Jika hasil < 8 digit → kemungkinan nama/bukan nomor\n",
        "    if len(nilai_bersih) < 8:\n",
        "        return np.nan\n",
        "\n",
        "    # Jika tidak ada digit sama sekali\n",
        "    if not any(c.isdigit() for c in nilai_bersih):\n",
        "        return np.nan\n",
        "\n",
        "    return nilai_bersih\n",
        "\n",
        "# Nama kolom HP — sesuaikan jika berbeda\n",
        "KOLOM_HP = df_clean.columns[5]  # kolom ke-6 (index 5)\n",
        "print(f\"\\n📱 Nama kolom HP terdeteksi: '{KOLOM_HP}'\")\n",
        "\n",
        "df_clean[KOLOM_HP] = df_clean[KOLOM_HP].apply(bersihkan_hp)\n",
        "\n",
        "hp_null = df_clean[KOLOM_HP].isna().sum()\n",
        "print(f\"   HP tidak valid/dikosongkan : {hp_null} baris\")\n",
        "\n",
        "# ── STEP 2: Bersihkan Spasi Berlebih di Semua Kolom ───────\n",
