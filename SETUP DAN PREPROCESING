        "def bersihkan_hp(nilai):\n",
        "    if pd.isna(nilai):\n",
        "        return np.nan\n",
        "    nilai = str(nilai).strip()\n",
        "    if nilai in ['-', '', ' ', 'nan']:\n",
        "        return np.nan\n",
        "    # Konversi +62 → 0\n",
        "    nilai = re.sub(r'^\\+62\\s*', '0', nilai)\n",
        "    nilai = re.sub(r'^\\+62', '0', nilai)\n",
        "    # Ambil digit saja dari awal\n",
        "    match = re.match(r'^(0[\\d\\s\\-]{7,14})', nilai)\n",
        "    if match:\n",
        "        nomor = re.sub(r'[\\s\\-]', '', match.group(1))\n",
        "        if len(nomor) >= 8:\n",
        "            return nomor\n",
        "    # Jika tidak ada digit valid → cek apakah ada angka sama sekali\n",
        "    hanya_angka = re.sub(r'[^\\d]', '', nilai)\n",
        "    if len(hanya_angka) >= 8 and hanya_angka.startswith(('08','62')):\n",
        "        if hanya_angka.startswith('62'):\n",
        "            hanya_angka = '0' + hanya_angka[2:]\n",
        "        return hanya_angka\n",
        "    return np.nan  # nama orang / tidak valid\n",
        "\n",
