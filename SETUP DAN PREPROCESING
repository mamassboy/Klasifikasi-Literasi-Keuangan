    {
      "cell_type": "code",
      "source": [
        "# 1. LOAD DATA DARI 1 SHEET GOOGLE FORMS\n",
        "sheet_id = \"1OgBoTgSJ6L-tFtvQYpbFbBYCVdq1op4M\"\n",
        "url = f\"https://docs.google.com/spreadsheets/d/{sheet_id}/export?format=csv\"\n",
        "\n",
        "print(\"Memuat data secara live dari Sheet Tunggal...\")\n",
        "df = pd.read_csv(url)\n",
        "\n",
        "# KUNCI SOLUSI MUTLAK: Menghapus kolom duplikat/kloningan bawaan Google Forms!\n",
        "df = df.loc[:, ~df.columns.duplicated()].copy()\n",
        "\n",
        "print(\"\\n=== TAHAP 1: INSPEKSI AWAL ===\")\n",
        "jumlah_baris = len(df)\n",
        "jumlah_kolom = len(df.columns)\n",
        "\n",
        "print(f\"Total Responden Saat Ini: {jumlah_baris} orang\")\n",
        "print(f\"Total Kolom/Pertanyaan (setelah deduplikasi): {jumlah_kolom} kolom\\n\")\n",
        "\n",
        "# 2. DETEKSI NAMA KOLOM OTOMATIS\n",
        "kolom_hp_list = [col for col in df.columns if 'hp' in col.lower() or 'telepon' in col.lower() or 'whatsapp' in col.lower()]\n",
        "kolom_hp = kolom_hp_list if len(kolom_hp_list) > 0 else None\n",
        "\n",
        "kolom_domisili_list = [col for col in df.columns if 'domisili' in col.lower() or 'asal' in col.lower() or 'kabupaten' in col.lower()]\n",
        "kolom_domisili = kolom_domisili_list if len(kolom_domisili_list) > 0 else None\n",
        "\n",
        "kolom_usia_list = [col for col in df.columns if 'usia' in col.lower() or 'umur' in col.lower()]\n",
        "kolom_usia = kolom_usia_list if len(kolom_usia_list) > 0 else None\n",
        "\n",
        "kolom_pendidikan_list = [col for col in df.columns if 'pendidikan' in col.lower()]\n",
        "kolom_pendidikan = kolom_pendidikan_list if len(kolom_pendidikan_list) > 0 else None\n",
        "\n",
        "# 3. PEMBERSIHAN DATA (CLEANING)\n",
        "def bersihkan_hp(text):\n",
        "    if pd.isna(text): return np.nan\n",
        "    text = str(text).lower()\n",
        "    # Hapus semua karakter yang bukan angka atau plus\n",
        "    text = re.sub(r'[^0-9\\+]', '', text)\n",
        "    # Tarik presisi nomor HP berawalan 08, 62, atau +62 diikuti 7-12 angka\n",
        "    match = re.search(r'((?:\\+62|62|08)[0-9]{7,12})', text)\n",
        "    return match.group(1) if match else np.nan\n",
        "\n",
        "def bersihkan_domisili(text):\n",
        "    if pd.isna(text): return 'Sumatera Utara (Lainnya)'\n",
        "    text_clean = str(text).lower().strip()\n",
        "    if text_clean in ['-', 'tidak ada', 'tidak tahu', 'nan', 'null', '']:\n",
        "        return 'Sumatera Utara (Lainnya)'\n",
        "    return str(text).strip().title()\n",
        "\n",
        "if kolom_hp and kolom_domisili:\n",
        "    # Dijamin tidak ambiguous karena kolom duplikat sudah dihancurkan\n",
        "    # Menggunakan kolom pertama dari list yang terdeteksi untuk pembersihan\n",
        "    df['No_HP_Bersih'] = df[kolom_hp[0]].apply(bersihkan_hp)\n",
        "    df['Domisili_Bersih'] = df[kolom_domisili[0]].apply(bersihkan_domisili)\n",
        "    print(\"✔️ Kolom Nomor HP berhasil dibersihkan dari teks aneh (dana, ovo, dll)!\")\n",
        "    print(\"✔️ Kolom Domisili kosong/tidak valid (-) berhasil diamankan!\")\n",
        "else:\n",
        "    print(\"Peringatan: Nama kolom HP atau Domisili tidak terdeteksi otomatis.\")\n",
        "\n",
        "# 4. EXPLORATORY DATA ANALYSIS (VISUALISASI EDA)\n",
        "print(\"\\n=== TAHAP 2: VISUALISASI EDA (STRATIFIKASI) ===\")\n",
        "sns.set_theme(style=\"whitegrid\")\n",
        "fig, axes = plt.subplots(1, 3, figsize=(18, 5))\n",
        "\n",
        "# Plot Usia\n",
        "if kolom_usia:\n",
        "    sns.countplot(y=kolom_usia[0], data=df, order=df[kolom_usia[0]].value_counts().index, palette='viridis', ax=axes[0])\n",
        "    axes[0].set_title('Distribusi Kelompok Usia', fontweight='bold')\n",
        "    axes[0].set_ylabel('')\n",
        "\n",
        "# Plot Pendidikan\n",
        "if kolom_pendidikan:\n",
        "    sns.countplot(y=kolom_pendidikan[0], data=df, order=df[kolom_pendidikan[0]].value_counts().index, palette='magma', ax=axes[1])\n",
        "    axes[1].set_title('Distribusi Tingkat Pendidikan', fontweight='bold')\n",
        "    axes[1].set_ylabel('')\n",
        "\n",
        "# Plot Domisili (Top 7)\n",
        "if 'Domisili_Bersih' in df.columns:\n",
        "    sns.countplot(y='Domisili_Bersih', data=df, order=df['Domisili_Bersih'].value_counts().iloc[:7].index, palette='plasma', ax=axes[2])\n",
        "    axes[2].set_title('Top 7 Domisili Responden', fontweight='bold')\n",
        "    axes[2].set_ylabel('')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# 5. TAMPILKAN HASIL PEMBERSIHAN SEBAGAI BUKTI\n",
        "if kolom_hp and kolom_domisili:\n",
